CONFIG=~/.jitsi-meet-cfg
TZ=Asia/Karachi
JITSI_IMAGE_VERSION=stable
RESTART_POLICY=unless-stopped
PUBLIC_URL=https://your-domain.com
HTTP_PORT=80
HTTPS_PORT=443
# Point to your Jitsi server over VPC/private networking if possible
XMPP_SERVER=your-domain.com
XMPP_PORT=5222
# These must match the Jitsi docker stack internal domains
#XMPP_DOMAIN=meet.jitsi
#XMPP_AUTH_DOMAIN=auth.meet.jitsi
#XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
#XMPP_MUC_DOMAIN=muc.meet.jitsi
#XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
# Helpful when XMPP cert names don't match the private host you use
#XMPP_TRUST_ALL_CERTS=1
ENABLE_RECORDING=1
JIBRI_RECORDER_USER=recorder
JIBRI_RECORDER_PASSWORD=your-generated-passwords-same-as-jitsi
JIBRI_XMPP_USER=jibri
JIBRI_XMPP_PASSWORD=your-generated-passwords-same-as-jitsi
JIBRI_BREWERY_MUC=jibribrewery
JIBRI_STRIP_DOMAIN_JID=muc
JIBRI_PENDING_TIMEOUT=90
JIBRI_RECORDING_DIR=/config/recordings
JIBRI_LOGS_DIR=/config/logs
