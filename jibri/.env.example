# Jibri Docker Environment Example
# Copy this file to .env on your Jibri EC2 and replace placeholders.
CONFIG=~/.jitsi-meet-cfg
TZ=Asia/Karachi
JITSI_IMAGE_VERSION=stable
RESTART_POLICY=unless-stopped
PUBLIC_URL=https://your-domain.example.com
HTTP_PORT=80
HTTPS_PORT=443
XMPP_SERVER=your-domain.example.com
XMPP_PORT=5222

# Optional internal domains, uncomment only if needed.
#XMPP_DOMAIN=meet.jitsi
#XMPP_AUTH_DOMAIN=auth.meet.jitsi
#XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
#XMPP_MUC_DOMAIN=muc.meet.jitsi
#XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
#XMPP_TRUST_ALL_CERTS=1

ENABLE_RECORDING=1
JIBRI_RECORDER_USER=recorder
JIBRI_RECORDER_PASSWORD=CHANGE_ME_SAME_AS_JITSI_ENV
JIBRI_XMPP_USER=jibri
JIBRI_XMPP_PASSWORD=CHANGE_ME_SAME_AS_JITSI_ENV
JIBRI_BREWERY_MUC=jibribrewery
JIBRI_STRIP_DOMAIN_JID=muc
JIBRI_PENDING_TIMEOUT=90
JIBRI_RECORDING_DIR=/config/recordings
JIBRI_LOGS_DIR=/config/logs
