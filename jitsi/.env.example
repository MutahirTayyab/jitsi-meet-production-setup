################################################################################
# Jitsi Meet Docker Environment Example
# Copy this file to .env on your Jitsi EC2 and replace placeholders.
################################################################################
CONFIG=~/.jitsi-meet-cfg
HTTP_PORT=80
HTTPS_PORT=443
DISABLE_HTTPS=0
ENABLE_HTTP_REDIRECT=1
PUBLIC_URL=https://your-domain.example.com
TZ=Asia/Karachi
XMPP_PORT=5222
ENABLE_LETSENCRYPT=0
ENABLE_XMPP_WEBSOCKET=1
ENABLE_RECORDING=1
ENABLE_FILE_RECORDING_SERVICE=1
ENABLE_LIVESTREAMING=1

JVB_ADVERTISE_IPS=YOUR_JITSI_PUBLIC_IP
DOCKER_HOST_ADDRESS=YOUR_JITSI_PUBLIC_IP

# Generate real values with ./gen-passwords.sh. Never commit real passwords.
JICOFO_AUTH_PASSWORD=CHANGE_ME_GENERATED_SECRET
JVB_AUTH_PASSWORD=CHANGE_ME_GENERATED_SECRET
JIGASI_XMPP_PASSWORD=CHANGE_ME_GENERATED_SECRET
JIGASI_TRANSCRIBER_PASSWORD=CHANGE_ME_GENERATED_SECRET
JIBRI_RECORDER_PASSWORD=CHANGE_ME_GENERATED_SECRET
JIBRI_XMPP_PASSWORD=CHANGE_ME_GENERATED_SECRET

JIBRI_RECORDER_USER=recorder
JIBRI_XMPP_USER=jibri
JIBRI_BREWERY_MUC=jibribrewery
JIBRI_STRIP_DOMAIN_JID=muc
JIBRI_PENDING_TIMEOUT=90
JIBRI_RECORDING_DIR=/config/recordings
JIBRI_LOGS_DIR=/config/logs

RESTART_POLICY=unless-stopped
JITSI_IMAGE_VERSION=stable
