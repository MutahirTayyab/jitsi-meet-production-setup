################################################################################
################################################################################
# Welcome to the Jitsi Meet Docker setup!
################################################################################
################################################################################
#
# Basic configuration options
#
CONFIG=~/.jitsi-meet-cfg
HTTP_PORT=80
HTTPS_PORT=443
DISABLE_HTTPS=0
ENABLE_HTTP_REDIRECT=1
# Replace with your real domain
PUBLIC_URL=https://your-domain.com
TZ=Asia/Karachi
XMPP_PORT=5222
ENABLE_LETSENCRYPT=0
#ENABLE_HTTP_REDIRECT=1
ENABLE_XMPP_WEBSOCKET=1
ENABLE_RECORDING=1
ENABLE_FILE_RECORDING_SERVICE=1
ENABLE_LIVESTREAMING=1
# Add this on EC2/NAT
# Replace with your Jitsi EC2 Elastic/Public IP
JVB_ADVERTISE_IPS=your-ec2-ip-or-your-server-ip
# Optional but useful on EC2
DOCKER_HOST_ADDRESS=your-ec2-ip-or-your-server-ip
#
# Memory limits for Java components
#
#JICOFO_MAX_MEMORY=3072m
#VIDEOBRIDGE_MAX_MEMORY=3072m
#
# Let's Encrypt configuration
#
# Turn this on only after iDNS is correctly pointing to your Jitsi server
#ENABLE_LETSENCRYPT=1
#LETSENCRYPT_DOMAIN=https://your-domain.com
#LETSENCRYPT_EMAIL=you@example.com
#LETSENCRYPT_USE_STAGING=1
#LETSENCRYPT_ACME_SERVER="letsencrypt"
#
# Authentication configuration
#
#ENABLE_AUTH=1
#ENABLE_GUESTS=1
#AUTH_TYPE=internal
#
# Security
# Keep your generated passwords exactly as they are
#
# XMPP password for Jicofo client connections
JICOFO_AUTH_PASSWORD=your-generated-passwords
# XMPP password for JVB client connections
JVB_AUTH_PASSWORD=your-generated-passwords
# XMPP password for Jigasi MUC client connections
JIGASI_XMPP_PASSWORD=your-generated-passwords
# XMPP password for Jigasi transcriber client connections
JIGASI_TRANSCRIBER_PASSWORD=your-generated-passwords
# XMPP recorder password for Jibri client connections
JIBRI_RECORDER_PASSWORD=your-generated-passwords
# XMPP password for Jibri client connections
JIBRI_XMPP_PASSWORD=your-generated-passwords
#
# Jibri settings
# Add these explicitly
#
JIBRI_RECORDER_USER=recorder
JIBRI_XMPP_USER=jibri
JIBRI_BREWERY_MUC=jibribrewery
JIBRI_STRIP_DOMAIN_JID=muc
JIBRI_PENDING_TIMEOUT=90
JIBRI_RECORDING_DIR=/config/recordings
JIBRI_LOGS_DIR=/config/logs
#
# Docker Compose options
#
RESTART_POLICY=unless-stopped
# Keep stable unless you need to pin a specific version
JITSI_IMAGE_VERSION=stable
